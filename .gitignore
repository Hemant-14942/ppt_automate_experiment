# OS
.DS_Store

# Local AI tool settings (do not commit)
.claude/settings.local.json
# Cursor local state (machine-specific)
.cursor/projects/

# Python
.venv/
venv/
__pycache__/
*.py[cod]
.env

# Runtime dirs (also in backend/.gitignore)
uploads/
outputs/
backend/uploads/
backend/outputs/

# Local-only smoke-test deps installed via pip --target (never deploy)
.smoke_deps/
backend/.smoke_deps/
# Smoke-test artifacts
backend/outputs/smoke_*

# Frontend (see frontend/.gitignore for full list)
frontend/node_modules/
frontend/.next/
frontend/out/

docs/
